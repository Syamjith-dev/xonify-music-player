<div class="row" >
    <div class="col-md-6 m-auto mt-5">
        <div class="container mt-5 pl-5">
            <h1 class="text-center" style="color: #ffff;">Login</h1>
            <form action="/login" method="post">
            {{#if loginErr}}
                <p class="error" style="margin-left: 260px;color:red;">{{loginErr}}</p>
            {{/if}}
                <div class="form-group mt-2">
                    <label class="col-form-label-lg">Email address</label>
                    <input type="email" class="form-control" name="email" placeholder="Enter email id">
                </div>
                <div class="form-group">
                    <label class="col-form-label-lg">Password</label>
                    <input type="password" class="form-control" name="password" placeholder="Enter password">
                </div>
                <a href="/sign-up" class="mt-3 d-inline-block" style="margin-left: 10px;text-decoration:none;">Create a
                    new Account?</a>
                <button type="submit" class="btn btn-primary" style="margin-left: 450px;">Login</button>
            

            </form>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-md-6 m-auto">
        <div class="container mt-5 pl-5">
            <h1 class="text-center">Create New Account</h1>
            <form action="/sign-up" method="post">
                <div class="form-group">
                    <label class="col-form-label-lg">Name</label>
                    <input type="name" class="form-control" name="name" placeholder="Enter your name">
                </div>
                <div class="form-group">
                    <label class="col-form-label-lg">Email address</label>
                    <input type="email" class="form-control" name="email" placeholder="Enter email id">
                </div>
                <div class="form-group">
                    <label class="col-form-label-lg">Password</label>
                    <input type="password" class="form-control" name="password" placeholder="Enter password">
                </div>
                <button type="submit" class="btn btn-primary mt-3" style="margin-left: 300px;">Sign up</button>
            </form>
        </div>
    </div>
</div>